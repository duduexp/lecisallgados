// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Categoria de produtos (Festa, Comércio, Bebidas)
model Category {
  id          String    @id @default(cuid())
  name        String
  description String?
  slug        String    @unique
  image       String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// Produtos (Salgados, Bebidas, etc)
model Product {
  id          String    @id @default(cuid())
  name        String
  description String?
  image       String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  active      Boolean   @default(true)
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Variações de preço (cru, frito, quantidade)
  variants    ProductVariant[]
  orderItems  OrderItem[]
}

// Variações do produto (tamanhos, tipos de preparo)
model ProductVariant {
  id          String      @id @default(cuid())
  productId   String
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String      // ex: "25 unidades - Cru", "Unitário - Frito"
  type        String      // "festa_cru", "festa_frito", "comercio_cru", "comercio_frito", "bebida", "espetinho"
  quantity    Int         // quantidade de unidades
  price       Float       // preço
  minQuantity Int         @default(1) // quantidade mínima para pedido
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

// Pedidos
model Order {
  id            String      @id @default(cuid())
  customerName  String
  customerPhone String
  customerEmail String?
  address       String?
  deliveryType  String      // "retirada" ou "entrega"
  notes         String?
  subtotal      Float
  deliveryFee   Float       @default(0)
  total         Float
  status        String      @default("pending") // pending, confirmed, preparing, ready, delivered, cancelled
  paymentMethod String?     // dinheiro, pix, cartao
  paymentStatus String      @default("pending") // pending, partial, paid
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  items         OrderItem[]
}

// Itens do pedido
model OrderItem {
  id            String          @id @default(cuid())
  orderId       String
  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product         @relation(fields: [productId], references: [id])
  variantId     String
  variant       ProductVariant  @relation(fields: [variantId], references: [id])
  productName   String          // nome do produto no momento do pedido
  variantName   String          // nome da variante no momento do pedido
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  notes         String?
  createdAt     DateTime        @default(now())
}

// Configurações do sistema
model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Admin para autenticação simples
model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hash da senha
  name      String?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
